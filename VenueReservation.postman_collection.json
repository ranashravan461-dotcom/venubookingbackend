        { "name": "Delete Venue Type", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/deleteVenueType/VENUE_TYPE_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "deleteVenueType", "VENUE_TYPE_ID_HERE"] } } },
