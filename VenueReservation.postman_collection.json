        { "name": "Verify Razorpay Payment", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/verifyPayment", "host": ["{{base_url}}"], "path": ["user", "verifyPayment"] }, "body": { "mode": "raw", "raw": "{\n  \"booking_id\": \"BOOKING_ID_HERE\",\n  \"razorpay_order_id\": \"order_XXXX\",\n  \"razorpay_payment_id\": \"pay_XXXX\",\n  \"razorpay_signature\": \"sig_XXXX\"\n}" } } },
        { "name": "Add Feedback", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/addFeedback", "host": ["{{base_url}}"], "path": ["user", "addFeedback"] }, "body": { "mode": "raw", "raw": "{\n  \"venue_id\": \"VENUE_ID_HERE\",\n  \"message\": \"Your venue is absolutely wonderful! The decorations and service were top-notch.\",\n  \"review\": \"Excellent\",\n  \"rating\": 5\n}" } } }
      ]
    },
