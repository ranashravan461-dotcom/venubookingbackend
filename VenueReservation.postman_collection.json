{
  "info": {
    "name": "Venue Discovery and Reservation Platform",
    "description": "Complete API collection for Venue Discovery and Reservation Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "base_url", "value": "http://localhost:8000", "type": "string" }],
  "item": [
    {
      "name": "🔐 Common",
      "item": [
        { "name": "Signup", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/signup", "host": ["{{base_url}}"], "path": ["signup"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Rahul Sharma\",\n  \"email\": \"rahul@gmail.com\",\n  \"phone\": \"9900000002\",\n  \"password\": \"Rahul@123\",\n  \"address\": \"22, Satellite Road, Ahmedabad\"\n}" } } },
        { "name": "Login (User)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"rahul@gmail.com\",\n  \"password\": \"Rahul@123\"\n}" } } },
        { "name": "Login (Admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@venue.com\",\n  \"password\": \"Admin@123\"\n}" } } },
        { "name": "Logout", "request": { "method": "GET", "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] } } },
        { "name": "Session", "request": { "method": "GET", "url": { "raw": "{{base_url}}/session", "host": ["{{base_url}}"], "path": ["session"] } } },
        { "name": "Change Password", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/changePassword", "host": ["{{base_url}}"], "path": ["changePassword"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"rahul@gmail.com\",\n  \"newPassword\": \"NewPass@123\"\n}" } } }
      ]
    },
    {
      "name": "🌐 Public",
      "item": [
        { "name": "Get All Cities", "request": { "method": "GET", "url": { "raw": "{{base_url}}/cities", "host": ["{{base_url}}"], "path": ["cities"] } } },
        { "name": "Get All Occasions", "request": { "method": "GET", "url": { "raw": "{{base_url}}/occasions", "host": ["{{base_url}}"], "path": ["occasions"] } } },
        { "name": "Get All Venue Types", "request": { "method": "GET", "url": { "raw": "{{base_url}}/venueTypes", "host": ["{{base_url}}"], "path": ["venueTypes"] } } },
        { "name": "Get All Venues", "request": { "method": "GET", "url": { "raw": "{{base_url}}/venues", "host": ["{{base_url}}"], "path": ["venues"] } } },
        { "name": "Get Venues — Filter by City", "request": { "method": "GET", "url": { "raw": "{{base_url}}/venues?city_id=CITY_ID_HERE", "host": ["{{base_url}}"], "path": ["venues"], "query": [{ "key": "city_id", "value": "CITY_ID_HERE" }] } } },
        { "name": "Get Venues — Filter by Occasion", "request": { "method": "GET", "url": { "raw": "{{base_url}}/venues?occasion_id=OCCASION_ID_HERE", "host": ["{{base_url}}"], "path": ["venues"], "query": [{ "key": "occasion_id", "value": "OCCASION_ID_HERE" }] } } },
        { "name": "Get Venues — Filter by Venue Type", "request": { "method": "GET", "url": { "raw": "{{base_url}}/venues?venue_type_id=VENUE_TYPE_ID_HERE", "host": ["{{base_url}}"], "path": ["venues"], "query": [{ "key": "venue_type_id", "value": "VENUE_TYPE_ID_HERE" }] } } },
        { "name": "Get Venues — Filter by Price Range", "request": { "method": "GET", "url": { "raw": "{{base_url}}/venues?min_price=50000&max_price=150000", "host": ["{{base_url}}"], "path": ["venues"], "query": [{ "key": "min_price", "value": "50000" }, { "key": "max_price", "value": "150000" }] } } },
        { "name": "Get Venue Details", "request": { "method": "GET", "url": { "raw": "{{base_url}}/venues/VENUE_ID_HERE", "host": ["{{base_url}}"], "path": ["venues", "VENUE_ID_HERE"] } } },
        { "name": "Get All Feedbacks", "request": { "method": "GET", "url": { "raw": "{{base_url}}/feedbacks", "host": ["{{base_url}}"], "path": ["feedbacks"] } } },
        { "name": "Get Feedbacks by Venue", "request": { "method": "GET", "url": { "raw": "{{base_url}}/feedbacks/VENUE_ID_HERE", "host": ["{{base_url}}"], "path": ["feedbacks", "VENUE_ID_HERE"] } } }
      ]
    },
    {
