        { "name": "Update Venue (with image)", "request": { "method": "POST", "url": { "raw": "{{base_url}}/admin/updateVenue", "host": ["{{base_url}}"], "path": ["admin", "updateVenue"] }, "body": { "mode": "formdata", "formdata": [{ "key": "id", "value": "VENUE_ID_HERE", "type": "text" }, { "key": "price", "value": "120000", "type": "text" }, { "key": "status", "value": "Active", "type": "text" }, { "key": "image", "src": "", "type": "file" }] } } },
        { "name": "Delete Venue", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/deleteVenue/VENUE_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "deleteVenue", "VENUE_ID_HERE"] } } },
